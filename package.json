{
  "name": "workhorse-monorepo",
  "version": "0.1.1",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/plugins/*",
    "oxlint/*"
  ],
  "scripts": {
    "dev": "cd packages/tui && bun run dev",
    "test": "bun run --filter '*' test",
    "build": "bun run --filter '*' build",
    "build:all": "bun run --filter workhorse-core build && bun run build:plugins && bun run build:tui:prod",
    "build:plugins": "bun scripts/build-plugins.ts",
    "build:tui": "bun scripts/build-tui",
    "build:tui:prod": "bun scripts/build-tui --minify --no-sourcemap",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "oxlint . --ignore-pattern 'packages/tui-worktrees/**'",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run test && bun run fallow",
    "prepare": "simple-git-hooks || true",
    "fallow": "fallow",
    "fallow:dead": "fallow dead-code",
    "fallow:dupes": "fallow dupes",
    "fallow:health": "fallow health",
    "fallow:audit": "fallow audit",
    "changelog": "changelogen",
    "release": "changelogen --release",
    "release:publish": "changelogen --release --publish"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@vitest/coverage-v8": "^4.1.6",
    "changelogen": "^0.6.1",
    "fallow": "^2.71.1",
    "lint-staged": "^17.0.4",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxfmt --write",
      "oxlint"
    ]
  }
}
