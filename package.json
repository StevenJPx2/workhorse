{
  "name": "jiratown",
  "private": true,
  "workspaces": ["packages/*", "oxlint/*"],
  "scripts": {
    "test": "bun test --recursive",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:fix": "oxfmt . --write",
    "check": "bun run lint && bun run test",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5",
    "oxlint": "^1.59.0",
    "@oxlint/plugins": "^1.59.0",
    "oxfmt": "^0.44.0",
    "simple-git-hooks": "^2.13.1",
    "lint-staged": "^16.4.0"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxfmt --write",
      "oxlint"
    ]
  }
}
