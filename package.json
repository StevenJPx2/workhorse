{
  "name": "workhorse-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/plugins/*",
    "oxlint/*"
  ],
  "scripts": {
    "dev": "cd packages/tui && bun run dev",
    "test": "bun run --filter '*' test",
    "build": "bun run --filter '*' build",
    "build:plugins": "bun scripts/build-plugins.ts",
    "build:tui": "bun scripts/build-tui.ts",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "oxlint . --ignore-pattern 'packages/tui-worktrees/**'",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:fix": "oxfmt . --write",
    "check": "bun run lint && bun run typecheck && bun run test && bun run fallow",
    "prepare": "simple-git-hooks || true",
    "fallow": "fallow",
    "fallow:dead": "fallow dead-code",
    "fallow:dupes": "fallow dupes",
    "fallow:health": "fallow health",
    "fallow:audit": "fallow audit",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@huggingface/transformers": "^4.2.0",
    "@types/bun": "latest",
    "@vitest/coverage-v8": "^4.1.6",
    "fallow": "^2.71.1",
    "lint-staged": "^17.0.4",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxfmt --write",
      "oxlint"
    ]
  }
}
