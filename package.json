{
  "name": "jiratown",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/plugins/*",
    "oxlint/*"
  ],
  "scripts": {
    "test": "bun run --filter '*' test",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:fix": "oxfmt . --write",
    "check": "bun run lint && bun run typecheck && bun run test && bun run fallow",
    "prepare": "simple-git-hooks",
    "fallow": "fallow",
    "fallow:dead": "fallow dead-code",
    "fallow:dupes": "fallow dupes",
    "fallow:health": "fallow health",
    "fallow:audit": "fallow audit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@vitest/coverage-v8": "^4.1.4",
    "fallow": "^2.42.0",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5",
    "vitest": "^4.1.4"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxfmt --write",
      "oxlint"
    ]
  }
}
