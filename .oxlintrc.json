{
  "$schema": "https://oxc.rs/docs/guide/usage/linter/config.html",
  "jsPlugins": ["./plugins/eslint-plugin-jiratown"],
  "ignorePatterns": [
    "plugins/**",
    "dist/**",
    "node_modules/**",
    "src/core/index.ts",
    "src/tui/hooks/use-notifications/use-notifications.ts",
    "src/tui/hooks/use-notifications/use-notifications.test.ts",
    "src/tui/hooks/use-agent-stream/__tests__/use-agent-stream.test.ts"
  ],
  "rules": {
    "jiratown/max-lines-per-file": ["error", 200],
    "jiratown/enforce-kebab-case-filenames": "warn",
    "jiratown/enforce-colocated-exports": "warn",
    "jiratown/prefer-composables-over-props": "warn",
    "jiratown/enforce-test-colocation": "warn"
  }
}
