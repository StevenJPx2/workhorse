{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "oxlint/eslint-plugin-jiratown/index.ts"
  ],
  "ignoreDependencies": [
    "@huggingface/transformers",
    "@mariozechner/pi-coding-agent",
    "sqlite-vec"
  ],
  "ignoreExports": [
    { "file": "packages/core/src/services/memory/index.ts", "exports": ["*"] },
    { "file": "packages/core/src/services/memory/l1/index.ts", "exports": ["*"] },
    { "file": "packages/core/src/services/memory/notifications/index.ts", "exports": ["*"] },
    { "file": "packages/core/src/services/memory/types.ts", "exports": ["*"] },
    { "file": "packages/core/src/services/memory/l1/serializer.ts", "exports": ["*"] },
    { "file": "packages/core/src/workflow/orchestrator/types/index.ts", "exports": ["JSONSchema"] },
    { "file": "packages/plugins/jira/src/auth.ts", "exports": ["loadCredentials", "saveCredentials", "clearCredentials"] },
    { "file": "packages/plugins/jira/src/parser.ts", "exports": ["canParseJira"] },
    { "file": "packages/plugins/pi-adapter/src/events.ts", "exports": ["EventHandlerContext", "ToolFactoryContext"] },
    { "file": "packages/core/src/workflow/orchestrator/steering/evaluator.ts", "exports": ["matchesCondition"] },
    { "file": "packages/plugins/github/src/monitor-notifications.ts", "exports": ["REVIEW_PRIORITIES", "PRMeta"] }
  ],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/**",
    "**/*.test.ts",
    "**/*.spec.ts",
    "oxlint/eslint-plugin-jiratown/index.js"
  ],
  "rules": {
    "unused-files": "warn",
    "unused-exports": "warn",
    "unused-types": "warn",
    "unused-dependencies": "error",
    "unused-class-members": "off",
    "circular-dependencies": "warn",
    "duplicate-exports": "error",
    "code-duplication": "warn",
    "complexity": "warn"
  },
  "health": {
    "maxCyclomatic": 25,
    "maxCognitive": 25,
    "failOnRefactoringTargets": false
  },
  "duplicates": {
    "minLines": 30
  }
}
