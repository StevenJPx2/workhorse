{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": ["**/*.test.ts", "**/*.spec.ts"],
  "ignoreDependencies": ["@huggingface/transformers", "playwright"],
  "ignoreExports": [
    { "file": "packages/core/src/services/memory/index.ts", "exports": ["*"] },
    {
      "file": "packages/core/src/services/memory/l1/index.ts",
      "exports": ["*"]
    },
    {
      "file": "packages/plugins/jira/src/parser.ts",
      "exports": ["canParseJira"]
    }
  ],
  "ignorePatterns": ["oxlint/eslint-plugin-workhorse/**"],
  "rules": {
    "unused-files": "warn",
    "unused-exports": "warn",
    "unused-types": "warn",
    "unused-dependencies": "error",
    "unused-class-members": "off",
    "circular-dependencies": "warn",
    "duplicate-exports": "warn",
    "coverage-gaps": "warn"
  },
  "health": {
    "maxCyclomatic": 25,
    "maxCognitive": 25,
    "ignore": ["**/*.test.ts", "**/*.spec.ts"]
  },
  "duplicates": {
    "minLines": 30
  }
}
