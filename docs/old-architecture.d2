# Jiratown Old Architecture (main branch)
# High-level overview of the tangled, monolithic architecture before rewrite

direction: right

title: {
  label: Jiratown Old Architecture
  near: top-center
  shape: text
  style.font-size: 24
  style.bold: true
}

# ═══════════════════════════════════════════════════════════════════
# Entry Points
# ═══════════════════════════════════════════════════════════════════

tui: TUI {
  style.fill: "#e3f2fd"
  modal: Modal
  chatbox: Chatbox
}

cli: CLI Input {
  style.fill: "#e3f2fd"
}

# ═══════════════════════════════════════════════════════════════════
# Core Monolith (Everything Tangled Together)
# ═══════════════════════════════════════════════════════════════════

core: "core/" {
  style.fill: "#fff3e0"
  style.stroke: "#e65100"
  style.stroke-width: 2

  # Orchestrator - does too much
  orchestrator: Agent Orchestrator {
    style.fill: "#ffecb3"
    spawn: spawn-agent.ts
    prompt: prompt-builder.ts
    mcp_config: mcp-config.ts
    health: health-check.ts
    store: agent-store.ts
  }

  # System Prompt - hardcoded instructions
  system_prompt: System Prompt {
    style.fill: "#ffecb3"
    initial: initial-prompt.ts
    resume: resume-prompt.ts
    system: system-prompt.ts
  }

  # Workflow - launch/halt/restart
  workflow: Ticket Workflow {
    style.fill: "#ffecb3"
    launch: launch.ts
    halt: halt.ts
    restart: restart.ts
  }

  # Session - memory scattered
  session: Session {
    style.fill: "#ffecb3"
    memory: session-memory.ts
    worktree: worktree/
    tmux: tmux/
  }

  # Notifications
  notifications: Notifications {
    style.fill: "#ffecb3"
    store: notification-store.ts
    inbox: system-instruction.ts
  }

  # Pollers - hardcoded, not extensible
  pollers: Pollers {
    style.fill: "#ffccbc"
    style.stroke: "#bf360c"
    jira: jira-poller.ts
    github: github-poller.ts
    agent: agent-poller.ts
    watcher: notification-watcher.ts
  }

  # External clients - baked into core
  jira: "jira/" {
    style.fill: "#ffccbc"
    style.stroke: "#bf360c"
    client: AtlassianClient
    fetch: fetchIssue
    sync: syncContext
  }

  github: "github/" {
    style.fill: "#ffccbc"
    style.stroke: "#bf360c"
    client: GitHubClient
    pr: fetchPRContext
    format: formatters
  }

  # MCP Server
  mcp: MCP Server {
    style.fill: "#ffecb3"
    tools: 5 Tools
  }

  # Database
  db: SQLite {
    style.fill: "#e8f5e9"
    tickets: tickets
    events: ticket_events
    notifs: notifications
  }
}

# ═══════════════════════════════════════════════════════════════════
# External Services
# ═══════════════════════════════════════════════════════════════════

external: External Services {
  style.fill: "#fce4ec"
  jira_api: Jira API
  github_api: GitHub API
}

# ═══════════════════════════════════════════════════════════════════
# Agent (Only OpenCode really supported)
# ═══════════════════════════════════════════════════════════════════

agent: Agent {
  style.fill: "#e8eaf6"
  opencode: OpenCode {
    style.fill: "#c5cae9"
  }
  claude: "Claude Code (stub)" {
    style.fill: "#cfd8dc"
    style.stroke-dash: 3
  }
}

# ═══════════════════════════════════════════════════════════════════
# Connections - The Tangled Web
# ═══════════════════════════════════════════════════════════════════

# Entry points to core
tui -> core.workflow: launch ticket
cli -> core.workflow: ticket key

# Workflow orchestrates everything
core.workflow -> core.orchestrator: spawn agent
core.workflow -> core.jira: fetch issue directly
core.workflow -> core.github: fetch PR context directly

# Orchestrator does too much
core.orchestrator -> core.system_prompt: generate prompt
core.orchestrator -> core.session: read/write context.md
core.orchestrator -> core.mcp: write config
core.orchestrator -> agent: spawn via tmux

# System prompt has hardcoded external knowledge
core.system_prompt -> core.jira: inline Jira instructions
core.system_prompt -> core.github: inline GitHub instructions

# Session memory is scattered
core.session.memory -> core.db: some state
core.notifications -> core.db: notifications table

# Pollers are created inline with spawning
core.orchestrator -> core.pollers: start pollers

# Pollers directly call external APIs
core.pollers.jira -> external.jira_api: poll comments
core.pollers.github -> external.github_api: poll reviews
core.pollers -> core.notifications: create notifications

# Notification injection via tmux
core.notifications -> agent: inject via tmux sendKeys

# Agent uses MCP
agent -> core.mcp: tool calls

# External clients inline in core
core.jira -> external.jira_api
core.github -> external.github_api

# ═══════════════════════════════════════════════════════════════════
# Legend
# ═══════════════════════════════════════════════════════════════════

legend: Legend {
  style.fill: "#fafafa"
  near: bottom-center

  tangled: "Jira/GitHub baked into core" {
    style.fill: "#ffccbc"
    style.stroke: "#bf360c"
  }
  core_module: "Core modules" {
    style.fill: "#ffecb3"
  }
  stub: "Stub/incomplete" {
    style.stroke-dash: 3
  }
}
