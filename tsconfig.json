{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "jsx": "preserve",
    "jsxImportSource": "@opentui/solid",
    "types": ["bun"],
    "lib": ["ESNext"],
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "#core": ["./src/core/index.ts"],
      "#core/*": ["./src/core/*"],
      "#tui/*": ["./src/tui/*"],
      "#cli/*": ["./src/cli/*"],
      "#types": ["./src/types/index.ts"],
      "#types/*": ["./src/types/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
