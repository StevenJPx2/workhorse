{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "types": ["bun", "vitest/globals"],
    "lib": ["ESNext"],
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": ["./**/*.ts"]
}
