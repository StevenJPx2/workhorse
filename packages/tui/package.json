{
  "name": "@fdcn/workhorse",
  "version": "0.1.0",
  "description": "Terminal UI for Workhorse - AI-powered issue resolver",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/StevenJPx2/workhorse.git",
    "directory": "packages/tui"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "main": "./dist/workhorse.js",
  "bin": {
    "workhorse": "./dist/workhorse.js"
  },
  "exports": {
    ".": "./dist/workhorse.js",
    "./plugin": "./src/plugin.ts",
    "./renderers": "./src/renderers/index.ts"
  },
  "scripts": {
    "build": "bun ../../scripts/build-tui.ts",
    "build:prod": "bun ../../scripts/build-tui.ts --minify --no-sourcemap",
    "dev": "bun src/index.tsx",
    "preview": "bun dist/workhorse.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "workhorse-core": "workspace:*",
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "workhorse-plugin-github": "workspace:*",
    "workhorse-plugin-jira": "workspace:*",
    "workhorse-plugin-pi-adapter": "workspace:*",
    "workhorse-plugin-playwright": "workspace:*",
    "@opentui/core": "0.2.1",
    "@opentui/solid": "0.2.1",
    "@types/bun": "latest",
    "solid-js": "^1.9.12",
    "typescript": "^6.0.3"
  }
}
