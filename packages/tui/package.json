{
  "name": "@jiratown/tui",
  "version": "0.1.0",
  "description": "Terminal UI for Jiratown - AI-powered Jira issue resolver",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/StevenJPx2/jiratown.git",
    "directory": "packages/tui"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/jiratown.js",
  "bin": {
    "jiratown": "./dist/jiratown.js"
  },
  "exports": {
    ".": "./dist/jiratown.js",
    "./plugin": "./src/plugin.ts",
    "./renderers": "./src/renderers/index.ts"
  },
  "scripts": {
    "build": "bun ../../scripts/build-tui.ts",
    "build:prod": "bun ../../scripts/build-tui.ts --minify",
    "dev": "bun src/index.tsx",
    "preview": "bun dist/jiratown.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@jiratown/core": "workspace:*",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@jiratown/plugin-github": "workspace:*",
    "@jiratown/plugin-jira": "workspace:*",
    "@jiratown/plugin-pi-adapter": "workspace:*",
    "@jiratown/plugin-playwright": "workspace:*",
    "@opentui/core": "0.2.1",
    "@opentui/solid": "0.2.1",
    "@types/bun": "latest",
    "solid-js": "^1.9.0",
    "typescript": "^5"
  }
}
