#!/usr/bin/env bun
/**
 * {{pascalCase name}}Service smoke.
 *
 *   bun scripts/smoke/{{kebabCase name}}.ts
 */
import { {{pascalCase name}}Service } from "#services";

import { context, narrator, sandbox, toolSink } from "./harness";

export async function {{camelCase name}}Smoke(): Promise<void> {
  const out = narrator("{{pascalCase name}}Service");
  const box = sandbox();

  try {
    const ctx = context(box.cwd);
    const tools = toolSink(ctx);
    const service = new {{pascalCase name}}Service(box.cwd);

    await service.setup(ctx);
    out.step(`setup discovered ${service.list().length} {{kebabCase name}} item(s)`);
    out.detail("contributed tools", [...tools.keys()]);

    service.teardown();
    out.done(`${service.name}: discover → setup → teardown`);
  } finally {
    box.dispose();
  }
}

if (import.meta.main) {
  await {{camelCase name}}Smoke();
}
