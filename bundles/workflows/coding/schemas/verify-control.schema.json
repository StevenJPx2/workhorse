{
  "type": "object",
  "required": ["verdict", "blocking"],
  "properties": {
    "verdict": { "type": "string", "enum": ["pass", "fail"] },
    "blocking": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "problem"],
        "properties": {
          "file": { "type": "string" },
          "problem": { "type": "string" },
          "impact": { "type": "string" }
        }
      }
    },
    "nits": { "type": "array", "items": { "type": "string" } },
    "delegate": {
      "type": "boolean",
      "description": "Set true ONLY when this stage's work genuinely exceeds your capability (not merely hard): the orchestrator re-runs the stage on a stronger model."
    },
    "delegateReason": { "type": "string" }
  }
}
