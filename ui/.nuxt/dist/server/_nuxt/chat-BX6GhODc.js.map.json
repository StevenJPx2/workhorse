{"file":"chat-BX6GhODc.js","mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAMA,UAAM,WAAW,IAAW,EAAE;AAC9B,UAAM,QAAQ,IAAI,EAAE;AACpB,UAAM,OAAO,IAAI,KAAK;AACtB,UAAM,MAAM,IAAA;AAEZ,mBAAe,OAAO;AACpB,YAAM,UAAU,MAAM,MAAM,KAAA;AAC5B,UAAI,CAAC,WAAW,KAAK,MAAO;AAC5B,eAAS,MAAM,KAAK,EAAE,MAAM,QAAQ,SAAS;AAC7C,YAAM,QAAQ;AACd,WAAK,QAAQ;AACb,YAAM,SAAS,MAAM,IAAI,OAAO,SAAS,EAAE,KAAK,IAAI,MAAM,aAAA,CAAc,CAAC;AACzE,UAAI;AACF,cAAM,IAAI,MAAM,OAA0B,aAAa;AAAA,UACrD,QAAQ;AAAA,UACR,MAAM,EAAE,UAAU,SAAS,MAAM,MAAM,GAAG,EAAA;AAAA,QAAE,CAC7C;AACD,iBAAS,MAAM,KAAK,EAAE,MAAM,aAAa,SAAS,EAAE,OAAO;AAAA,MAC7D,SAAS,GAAY;AACnB,iBAAS,MAAM,KAAK,EAAE,MAAM,aAAa,SAAS,MAAM,OAAO,CAAC,CAAC,GAAA,CAAI;AAAA,MACvE,UAAA;AACE,aAAK,QAAQ;AACb,cAAM,SAAS,MAAM,IAAI,OAAO,SAAS,EAAE,KAAK,IAAI,MAAM,aAAA,CAAc,CAAC;AAAA,MAC3E;AAAA,IACF;;;;;QAIO,OAAM;AAAA,QAAgB,OAAA,EAAA,UAAA,qBAAA;AAAA,MAAA,GAAA,MAAA,CAAA,CAAA,sDAAA;AAEX,UAAA,CAAAA,MAAA,QAAA,EAAS,QAAM;;;;;;AAILC,oBAAAD,MAAA,QAAA,GAAQ,CAAjB,GAAG,MAAC;6BAA6CE,eAAA,CAAA,EAAE,SAAI,SAAA,gBAAA,iBAAA,MAAA,CAAA,CAAA,iBAGxDA,eAAA,CAAA,EAAE,SAAI,SAAA,kBAAA,eAAA,8DAAA,CAAA,CAAA,KAEXC,eAAA,EAAE,OAAO,CAAA,cAAA;AAAA;;AAGL,UAAAH,MAAA,IAAA,GAAI;;;;;;;QAIJ,YAAAA,MAAA,KAAA;AAAA,QAAA,uBAAA,CAAA,WAAAI,MAAA,KAAA,IAAA,MAAK,QAAA,SAAA;AAAA,QACd,OAAM;AAAA,QACN,aAAY;AAAA,QACX,UAAUJ,MAAA,IAAA;AAAA,QACV,WAAe;AAAA,MAAA,GAAA,MAAA,OAAA,CAAA;;QAER,SAASA,MAAA,IAAA;AAAA,QAAO,UAAQ,CAAGA,MAAA,KAAA,EAAM,KAAA;AAAA,QAAQ,MAAK;AAAA,QAAiB,SAAO;AAAA,MAAA,GAAA,MAAA,OAAA,CAAA;;;;;;;;;;;","names":["_unref","_ssrRenderList","_ssrRenderClass","_ssrInterpolate","_isRef"],"sources":["../../../../app/pages/chat.vue"],"sourcesContent":["<script setup lang=\"ts\">\ninterface Msg {\n  role: \"user\" | \"assistant\";\n  content: string;\n}\n\nconst messages = ref<Msg[]>([]);\nconst input = ref(\"\");\nconst busy = ref(false);\nconst box = ref<HTMLElement>();\n\nasync function send() {\n  const content = input.value.trim();\n  if (!content || busy.value) return;\n  messages.value.push({ role: \"user\", content });\n  input.value = \"\";\n  busy.value = true;\n  await nextTick(() => box.value?.scrollTo({ top: box.value.scrollHeight }));\n  try {\n    const r = await $fetch<{ reply: string }>(\"/api/chat\", {\n      method: \"POST\",\n      body: { messages: messages.value.slice(-12) },\n    });\n    messages.value.push({ role: \"assistant\", content: r.reply });\n  } catch (e: unknown) {\n    messages.value.push({ role: \"assistant\", content: `⚠️ ${String(e)}` });\n  } finally {\n    busy.value = false;\n    await nextTick(() => box.value?.scrollTo({ top: box.value.scrollHeight }));\n  }\n}\n</script>\n\n<template>\n  <div class=\"flex flex-col\" style=\"height: calc(100vh - 8rem)\">\n    <div ref=\"box\" class=\"flex-1 overflow-y-auto space-y-3 pb-4\">\n      <div v-if=\"!messages.length\" class=\"text-muted text-sm pt-8 text-center\">\n        Talk to the fleet agent — file tickets, check status, stop runs, steer work.<br />\n        e.g. <em>\"What's running right now?\"</em> · <em>\"Stop ticket 1dc5f927 and refile it with a stricter scope\"</em>\n      </div>\n      <div v-for=\"(m, i) in messages\" :key=\"i\" class=\"flex\" :class=\"m.role === 'user' ? 'justify-end' : 'justify-start'\">\n        <div\n          class=\"rounded-lg px-3 py-2 max-w-[85%] text-sm whitespace-pre-wrap\"\n          :class=\"m.role === 'user' ? 'bg-primary/10' : 'bg-elevated'\"\n        >\n          {{ m.content }}\n        </div>\n      </div>\n      <div v-if=\"busy\" class=\"text-muted text-sm animate-pulse\">agent thinking…</div>\n    </div>\n    <div class=\"flex gap-2 pt-2 border-t border-default\">\n      <UInput\n        v-model=\"input\"\n        class=\"flex-1\"\n        placeholder=\"Message the fleet agent…\"\n        :disabled=\"busy\"\n        @keydown.enter=\"send\"\n      />\n      <UButton :loading=\"busy\" :disabled=\"!input.trim()\" icon=\"i-lucide-send\" @click=\"send\" />\n    </div>\n  </div>\n</template>\n"],"version":3}